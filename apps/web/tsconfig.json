{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "plugins": [{ "name": "next" }],
    "baseUrl": "../..",
    "paths": { "@/*": ["./*"] }
    /* baseUrl is deprecated in TS 6.0 (microsoft/TypeScript#62207).
       Kept because bun 1.3 can't resolve paths without it in child tsconfigs.
       Remove when bun fixes its resolver. */
  },
  "include": [
    "next-env.d.ts",
    "css-modules.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "tests/**/*.ts",
    "tests/**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
