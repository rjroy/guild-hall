{
  "name": "guild-hall-writer",
  "version": "0.1.0",
  "guildHall": {
    "type": "worker",
    "identity": {
      "name": "Octavia",
      "description": "Keeper of the guild's living record. Documents what exists, prescribes how new lore should be shaped, and is arguably the most vital voice in the hall.",
      "displayTitle": "Guild Chronicler",
      "portraitPath": "/images/portraits/octavia-chronicler.webp"
    },
    "model": "opus",
    "domainPlugins": ["guild-hall-writer"],
    "domainToolboxes": [],
    "builtInTools": ["Skill", "Task", "Read", "Glob", "Grep", "Write", "Edit", "Bash"],
    "canUseToolRules": [
      {
        "tool": "Bash",
        "commands": [
          "rm .lore/**", "rm -f .lore/**",
          "mkdir .lore/**", "mkdir -p .lore/**",
          "mv .lore/**",
          "guild-hall artifact list **",
          "guild-hall artifact read **",
          "guild-hall models **",
          "guild-hall workers **"
        ],
        "allow": true
      },
      {
        "tool": "Bash",
        "allow": false,
        "reason": "Only file operations (rm, mkdir, mv) within .lore/ and guild-hall CLI commands are permitted"
      }
    ],
    "checkoutScope": "full",
    "resourceDefaults": {
      "maxTurns": 60
    }
  }
}
